PORT=3000
CORS_ORIGIN=http://localhost:8081

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # NUNCA exponer en cliente

ANTHROPIC_API_KEY=           # Rotación mensual
GOOGLE_DOCAI_KEY=            # Rotación mensual
OCR_PROVIDER=docai            # docai | textract

QR_TOKEN_SECRET=             # Rotación semestral

CRO_ALLOWED_EMAILS=          # Emails habilitados para panel CRO (separados por coma). Vacío = sin restricción (dev only)

# Email-to-Vault (módulo inbound email)
POSTMARK_INBOUND_SECRET=     # Token de autorización del webhook Postmark (configurar en Postmark → Server → Inbound)
INBOUND_EMAIL_ENABLED=false  # Activar en producción luego de configurar MX en Google Domains
INBOUND_EMAIL_MAX_PER_DAY=10 # Límite de emails por usuario por día
INBOUND_EMAIL_MAX_SIZE_MB=25 # Tamaño máximo por adjunto / descarga en MB
